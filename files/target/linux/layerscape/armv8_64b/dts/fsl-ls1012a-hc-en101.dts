// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
/*
 * Device Tree file for Huaichen Telecom HC-EN101 (TE1104H0)
 * Based on NXP LS1012A SoC
 *
 * Boot flow (from U-Boot printenv):
 *   QSPI NOR: RCW(64KB@0x0) + U-Boot(640KB@0x100000)
 *   eMMC:     p1(ext4,fitImage) + p2(squashfs,rootfs)
 *   U-Boot:  ext4load mmc 0:1 fitImage -> bootm
 *
 * Hardware info from serial console (verified):
 *   - RAM: ~990MB (0x3BE00000) @ 0x80000000
 *   - 2x PFE Ethernet with RealTek RTL8211F PHY (RGMII)
 *     MDIO addr 1 -> pfe_eth1, MDIO addr 2 -> pfe_eth0
 *   - eMMC: DG400 7.3GiB (boot device for kernel+rootfs)
 *   - QSPI NOR: Macronix MX25U12835F 16MB (only RCW + U-Boot)
 */

/dts-v1/;

#include "fsl-ls1012a.dtsi"

/ {
	model = "Huaichen Telecom HC-EN101";
	compatible = "hctele,hc-en101", "fsl,ls1012a";

	aliases {
		ethernet0 = &pfe_mac0;
		ethernet1 = &pfe_mac1;
		mmc0 = &esdhc;
	};

	chosen {
		stdout-path = &duart0;
		bootargs = "console=ttyS0,115200 root=/dev/mmcblk0p2 rootfstype=squashfs rootwait earlycon=uart8250,mmio,0x21c0500";
	};

	memory@80000000 {
		device_type = "memory";
		/* 990MB DDR - from bdinfo: size = 0x3BE00000 */
		reg = <0x0 0x80000000 0x0 0x3BE00000>;
	};

	leds {
		compatible = "gpio-leds";

		/*
		 * TODO: Verify GPIO numbers from schematic or
		 * U-Boot: 'gpio status' or 'gpio input'
		 */
		led-power {
			label = "hc-en101:green:power";
			gpios = <&gpio0 0 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		led-wan {
			label = "hc-en101:green:wan";
			gpios = <&gpio0 1 GPIO_ACTIVE_LOW>;
		};

		led-lan {
			label = "hc-en101:green:lan";
			gpios = <&gpio0 2 GPIO_ACTIVE_LOW>;
		};
	};

	gpio-keys-polled {
		compatible = "gpio-keys-polled";
		poll-interval = <20>;

		/*
		 * TODO: Verify reset button GPIO.
		 * Check U-Boot: 'gpio input' or schematic.
		 */
		reset {
			label = "reset";
			gpios = <&gpio0 3 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};
	};
};

&duart0 {
	status = "okay";
};

&i2c0 {
	status = "okay";
};

/*
 * eMMC - Primary boot storage for kernel + rootfs
 * U-Boot: ext4load mmc 0:1 0xa0000000 fitImage
 * Kernel: root=/dev/mmcblk0p2 rootfstype=squashfs
 */
&esdhc {
	status = "okay";
};

/*
 * QSPI NOR Flash - Only stores bootloader (RCW + U-Boot)
 * NOT used for kernel/rootfs (those are on eMMC)
 *
 * Verified with 'sf probe 0:0':
 *   Macronix MX25U12835F, 16MB total, 256B page, 64KB erase
 */
&qspi {
	status = "okay";

	flash0: flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;
		m25p,fast-read;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			/* RCW/PBL - Reset Configuration Word */
			partition@0 {
				label = "rcw";
				reg = <0x00000000 0x00010000>; /* 64KB */
				read-only;
			};

			/* U-Boot bootloader */
			partition@100000 {
				label = "uboot";
				reg = <0x00100000 0x000a0000>; /* 640KB */
				read-only;
			};

			/* U-Boot environment */
			partition@1a0000 {
				label = "uboot-env";
				reg = <0x001a0000 0x00060000>; /* 384KB */
			};
		};
	};
};

/*
 * PFE (Packet Forwarding Engine) - Two Ethernet MACs
 *
 * Verified from U-Boot serial console:
 *   mdio list:
 *     1 - RealTek RTL8211F <--> pfe_eth1
 *     2 - RealTek RTL8211F <--> pfe_eth0
 *   mii info: OUI=0x0732 Model=0x11 (RTL8211F)
 *
 * RTL8211F is an RGMII Gigabit PHY, NOT SGMII.
 * phy-mode must be "rgmii-id" (RGMII with internal delay).
 *
 * PHY address mapping:
 *   pfe_eth0 -> MDIO addr 2 (gemac0_phy)
 *   pfe_eth1 -> MDIO addr 1 (gemac1_phy)
 */
&pfe {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	pfe_mac0: ethernet@0 {
		compatible = "fsl,pfe-gemac-port";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0x0>;
		phy-handle = <&gemac0_phy>;
		phy-mode = "rgmii-id";
	};

	pfe_mac1: ethernet@1 {
		compatible = "fsl,pfe-gemac-port";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0x1>;
		phy-handle = <&gemac1_phy>;
		phy-mode = "rgmii-id";
	};

	mdio@0 {
		#address-cells = <1>;
		#size-cells = <0>;

		/* pfe_eth0 uses MDIO addr 2 */
		gemac0_phy: ethernet-phy@2 {
			reg = <0x2>;
			compatible = "ethernet-phy-id001c.c911";
		};

		/* pfe_eth1 uses MDIO addr 1 */
		gemac1_phy: ethernet-phy@1 {
			reg = <0x1>;
			compatible = "ethernet-phy-id001c.c911";
		};
	};
};
